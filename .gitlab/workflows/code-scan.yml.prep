code-scan:
  stage: post-build-test-stage
  needs: [ build-image, kosli-trail ]
  script:
    - set +e
    - snyk code test
        --policy-path=.snyk
        --sarif
        --sarif-file-output=snyk.code.scan.json
        .
    - STATUS=$?
    - set -e

    - cp .snyk "${KOSLI_ATTACHMENTS}"
    - kosli attest snyk ${IMAGE_NAME}
        --name=creator.snyk-code-scan
        --scan-results=snyk.code.scan.json

    - exit ${STATUS}
